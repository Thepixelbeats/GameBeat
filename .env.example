# Supabase runtime connection via transaction pooler.
DATABASE_URL="postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Supabase direct/session connection for Prisma migrations and seed.
DIRECT_URL="postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
# No extra environment variables are required for the default Vercel Analytics setup.
# Configure at least one sign-in provider before deploying.
# If you only want Google sign-in, leave the email variables blank.
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"
EMAIL_SERVER="smtp://username:password@smtp.example.com:587"
EMAIL_FROM="GameFlow <no-reply@example.com>"
